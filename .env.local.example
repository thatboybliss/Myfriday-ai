# Environment Configuration Template
# 
# INSTRUCTIONS:
# 1. Copy this file and rename it to .env.local
# 2. Replace the placeholder values below with your actual API keys
# 3. Never commit .env.local to the repository - it's already in .gitignore
# 4. Keep this file (.env.local.example) with placeholder values as documentation

NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here
NEXT_PUBLIC_ANTHROPIC_API_KEY=your_anthropic_api_key_here
NEXT_PUBLIC_GROK_API_KEY=your_grok_api_key_here